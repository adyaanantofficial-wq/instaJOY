# Supabase configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional direct PostgreSQL connection for applying the schema locally
SUPABASE_DB_URL=postgres://username:password@host:port/database
DATABASE_URL=postgres://username:password@host:port/database
SUPABASE_BUCKET_POSTS=post-images
SUPABASE_BUCKET_REELS=reel-videos

# Firebase Cloud Messaging configuration
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_VAPID_KEY=your-firebase-vapid-key

# MongoDB for analytics/logging only
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/instajoy-logs?retryWrites=true&w=majority
MONGODB_DB=instajoy_logs

# Frontend
FRONTEND_URL=https://your-github-username.github.io/instaJOY
FRONTEND_URLS=https://your-github-username.github.io/instaJOY,http://127.0.0.1:5500,http://localhost:5500

# Optional runtime settings
PORT=3000
NODE_ENV=development

# NOTE: MONGODB_URI must come from your environment on Railway or from a local .env file.
# Do not commit real secrets. GitHub Pages requires the backend URL to point at your Railway app.
