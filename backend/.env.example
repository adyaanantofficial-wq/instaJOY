PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/instajoy?retryWrites=true&w=majority&appName=instaJOY
MONGODB_DB=instajoy
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-separate-long-random-secret
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=https://your-github-username.github.io
FRONTEND_URLS=https://your-github-username.github.io,http://127.0.0.1:5500,http://localhost:5500
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=150
